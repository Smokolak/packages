From 142aef56b44076f69dac8d91f5162a0723f18be4 Mon Sep 17 00:00:00 2001
From: Vlad Zahorodnii <vlad.zahorodnii@kde.org>
Date: Thu, 26 Mar 2026 12:27:38 +0000
Subject: [PATCH] Bug 1996252 - [Wayland] Fix input breaking after resizing a
 picture-in-picture window, r=stransky

When a picture-in-picture window asks to be moved or resized, the
compositor will take over the pointer input. The client will not receive
the corresponding button release event.

We need to call gdk_seat_ungrab() so GDK resets its internal state.
Wayland GDK code does the same thing when it starts an interactive move
or resize operation.

Differential Revision: https://phabricator.services.mozilla.com/D289325
---
 widget/gtk/WidgetUtilsGtk.cpp | 17 +++++++++++++++++
 widget/gtk/WidgetUtilsGtk.h   |  4 ++++
 widget/gtk/nsWindow.cpp       |  8 ++++++++
 3 files changed, 29 insertions(+)

diff --git a/widget/gtk/WidgetUtilsGtk.cpp b/widget/gtk/WidgetUtilsGtk.cpp
index 32bced9cea3f6..6683aa2c338fd 100644
--- a/widget/gtk/WidgetUtilsGtk.cpp
+++ b/widget/gtk/WidgetUtilsGtk.cpp
@@ -141,6 +141,23 @@ GdkDevice* GdkGetPointer() {
   return gdk_device_manager_get_client_pointer(deviceManager);
 }
 
+GdkSeat* GdkDeviceGetSeat(GdkDevice* device) {
+  static auto sGdkDeviceGetSeat =
+      (GdkSeat * (*)(GdkDevice*)) dlsym(RTLD_DEFAULT, "gdk_device_get_seat");
+  if (!sGdkDeviceGetSeat) {
+    return nullptr;
+  }
+  return sGdkDeviceGetSeat(device);
+}
+
+void GdkSeatUngrab(GdkSeat* seat) {
+  static auto sGdkSeatUngrab =
+      (void (*)(GdkSeat*))dlsym(RTLD_DEFAULT, "gdk_seat_ungrab");
+  if (sGdkSeatUngrab) {
+    sGdkSeatUngrab(seat);
+  }
+}
+
 static GdkEvent* sLastPointerDownEvent = nullptr;
 GdkEvent* GetLastPointerDownEvent() { return sLastPointerDownEvent; }
 
diff --git a/widget/gtk/WidgetUtilsGtk.h b/widget/gtk/WidgetUtilsGtk.h
index 585491ac35e74..4f19c6a20e48a 100644
--- a/widget/gtk/WidgetUtilsGtk.h
+++ b/widget/gtk/WidgetUtilsGtk.h
@@ -14,6 +14,7 @@ typedef struct _GdkDisplay GdkDisplay;
 typedef struct _GdkDevice GdkDevice;
 typedef struct _GError GError;
 typedef union _GdkEvent GdkEvent;
+typedef struct _GdkSeat GdkSeat;
 class nsWindow;
 
 namespace mozilla::widget {
@@ -36,6 +37,9 @@ bool IsXWaylandProtocol();
 
 GdkDevice* GdkGetPointer();
 
+GdkSeat* GdkDeviceGetSeat(GdkDevice* device);
+void GdkSeatUngrab(GdkSeat* seat);
+
 // Sets / returns the last mouse button press/touch begin event we processed.
 void SetLastPointerDownEvent(GdkEvent*);
 GdkEvent* GetLastPointerDownEvent();
diff --git a/widget/gtk/nsWindow.cpp b/widget/gtk/nsWindow.cpp
index ab4d8f533194e..352ccf95c294e 100644
--- a/widget/gtk/nsWindow.cpp
+++ b/widget/gtk/nsWindow.cpp
@@ -4494,6 +4494,10 @@ void nsWindow::OnMotionNotifyEvent(GdkEventMotion* aEvent) {
         xx_pip_v1_move(mPipResources.mPipSurface,
                        gdk_wayland_device_get_wl_seat(GdkGetPointer()),
                        nsWaylandDisplay::GetLastEventSerial());
+        // The ungrab is needed because the compositor won't send a button
+        // release event. GDK may get stuck thinking that the implicit grab is
+        // still active.
+        GdkSeatUngrab(GdkDeviceGetSeat(GdkGetPointer()));
         return;
       }
 #endif
@@ -4817,6 +4821,10 @@ void nsWindow::OnButtonPressEvent(GdkEventButton* aEvent) {
       xx_pip_v1_resize(mPipResources.mPipSurface,
                        gdk_wayland_device_get_wl_seat(GdkGetPointer()),
                        nsWaylandDisplay::GetLastEventSerial(), pipEdges);
+      // The ungrab is needed because the compositor won't send a button release
+      // event. GDK may get stuck thinking that the implicit grab is still
+      // active.
+      GdkSeatUngrab(GdkDeviceGetSeat(GdkGetPointer()));
       return;
     }
 #endif
